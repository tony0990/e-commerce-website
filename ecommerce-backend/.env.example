# ===========================================
# E-Commerce Backend - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# --- Application ---
APP_NAME=E-Commerce API
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- Database ---
# SQLite (Development)
DATABASE_URL=sqlite+aiosqlite:///./ecommerce.db

# MySQL (Production)
# DATABASE_URL=mysql+aiomysql://user:password@localhost:3306/ecommerce_db

# --- JWT Authentication ---
SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Redis Cache ---
REDIS_URL=redis://localhost:6379/0
CACHE_EXPIRE_SECONDS=300

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000","http://localhost:5500","http://127.0.0.1:5500"]

# --- Admin Account ---
ADMIN_EMAIL=admin@ecommerce.com
ADMIN_PASSWORD=Admin@123456
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
